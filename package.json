{
  "name": "pawsome4pets",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Luxury kennel-free dog boarding — Pawsome4Pets (PTY) LTD",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"vite\" \"npm --prefix server run dev\"",
    "dev:web": "vite",
    "dev:api": "npm --prefix server run dev",
    "build": "vite build",
    "preview": "vite preview",
    "server:install": "npm --prefix server install",
    "server:migrate": "npm --prefix server run prisma:migrate",
    "server:seed": "npm --prefix server run seed",
    "vercel-build": "prisma generate --schema=./server/prisma/schema.prod.prisma && vite build",
    "prod:db:push": "dotenv -e ./server/.env.production -- prisma db push --schema=./server/prisma/schema.prod.prisma",
    "prod:db:deploy": "dotenv -e ./server/.env.production -- prisma migrate deploy --schema=./server/prisma/schema.prod.prisma",
    "prod:db:seed": "dotenv -e ./server/.env.production -- node ./server/prisma/seed.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^0.27.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "framer-motion": "^11.3.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.9",
    "pdfkit": "^0.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.26.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.1",
    "dotenv-cli": "^11.0.0",
    "mysql2": "^3.22.4",
    "postcss": "^8.4.40",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.7",
    "vite": "^5.3.5"
  }
}
