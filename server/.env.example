# MySQL connection.
#
# Local dev (with MySQL installed locally):
#   DATABASE_URL="mysql://root:password@localhost:3306/pawsome4pets"
#
# Afrihost cPanel (MySQL/MariaDB):
#   1. cPanel → MySQL Databases — create a DB (e.g. "myacct_pawsome4pets")
#      and a user; grant the user ALL PRIVILEGES on the DB.
#   2. cPanel → Remote MySQL — add the IP of wherever the API server runs
#      (your VPS, Render outbound IP, etc.) so it's allowed to connect.
#   3. Connection string format:
#        mysql://<dbuser>:<dbpassword>@<host>:3306/<dbname>
#      Host is usually your domain (e.g. pawsome4pets.co.za) or the IP
#      shown on the cPanel MySQL page. Username and DB name are prefixed
#      with your cPanel account name (e.g. "myacct_pawsome").
DATABASE_URL="mysql://myacct_user:password@your-domain.co.za:3306/myacct_pawsome4pets"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS — the Vite dev origin
CLIENT_ORIGIN="http://localhost:5173"

# Bootstrap admin (used by `npm run seed`)
ADMIN_EMAIL="admin@pawsome4pets.co.za"
ADMIN_PASSWORD="ChangeMeNow!"
ADMIN_NAME="Site Admin"

# Bcrypt
BCRYPT_ROUNDS=12

# Email (SMTP). Leave SMTP_HOST blank in dev to use the console log fallback.
# For production, fill in your outgoing-mail credentials (Afrihost: mail.<yourdomain>:587).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Pawsome 4 Pets <noreply@pawsome4pets.co.za>"
RESET_URL_BASE="http://localhost:5173"
